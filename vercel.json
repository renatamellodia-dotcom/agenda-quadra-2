{
  "buildCommand": "cd melodia-project && npm install && npm run build",
  "outputDirectory": "melodia-project/dist",
  "functions": {
    "api/webhook.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
